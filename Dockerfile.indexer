# Dockerfile for Midnight Indexer
FROM node:18-alpine

# Install dependencies
RUN apk add --no-cache \
    curl \
    bash \
    postgresql-client

# Install indexer
RUN npm install -g @midnight-ntwrk/indexer

# Create working directory
WORKDIR /app

# Expose port
EXPOSE 8088

# Health check
HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
    CMD curl -f http://localhost:8088/health || exit 1

# Start indexer
CMD ["midnight-indexer", "start"]
