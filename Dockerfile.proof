# Dockerfile for Midnight Proof Server
FROM node:18-alpine

# Install dependencies
RUN apk add --no-cache \
    curl \
    bash \
    python3

# Install proof server
RUN npm install -g @midnight-ntwrk/proof-server

# Create working directory
WORKDIR /app

# Expose port
EXPOSE 6300

# Health check
HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
    CMD curl -f http://localhost:6300/health || exit 1

# Start proof server
CMD ["midnight-proof-server", "start", "--port", "6300"]
